# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Resend
RESEND_API_KEY=re_your-api-key

# 국세청 사업자번호 확인 API (공공데이터포털)
NTS_API_KEY=your-nts-api-key

# Octomo MO 인증 (휴대폰 본인인증) — https://www.octoverse.kr
# MO 방식: 사용자가 코드를 직접 SMS 발송 → 서버가 수신 여부 확인 (무료)
# API_KEY: Octomo 마이페이지에서 발급
# RECEIVING_NUMBER: Octomo 대시보드에서 확인하는 수신 전용 번호 (070 또는 0X0 번호)
OCTOMO_API_KEY=your-octomo-api-key
OCTOMO_RECEIVING_NUMBER=07012345678

# Sentry
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/your-project

# 크롤링 서비스 (Railway, Stage 3+)
CRAWLER_SERVICE_URL=https://your-crawler.railway.app
CRAWLER_API_KEY=your-internal-key

# Toss Payments (Stage 4+)
TOSS_PAYMENTS_CLIENT_KEY=test_ck_your-client-key
TOSS_PAYMENTS_SECRET_KEY=test_sk_your-secret-key
